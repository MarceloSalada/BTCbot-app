{
  "name": "btcbot-app",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "build:web": "npm run build -w apps/web",
    "start:web": "npm run start -w apps/web",
    "dev:executor": "npm run dev -w apps/executor",
    "start:executor": "npm run start -w apps/executor",
    "backtest": "npm run backtest -w apps/executor"
  }
}
